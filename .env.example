# ── AI Model ──────────────────────────────────────────────────────────────────
AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# ── Kite x402 Payment ─────────────────────────────────────────────────────────
PAY_TO_ADDRESS=0x4812fC05e79ddc616346d10A8826B2bdf5e6ab20
# Pieverse facilitator — NOT x402.org (see KITE_X402_PATCH.md)
FACILITATOR_URL=https://facilitator.pieverse.io

# ── Kite chain ────────────────────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
KITE_CHAIN_ID=2368

# Payment token: Kite X402 USD (KXUSD) on Kite testnet, 18 decimals
TESTNET_ASSET=0x1b7425d288ea676FCBc65c29711fccF0B6D5c293
X402_EIP712_DOMAIN_NAME=Kite X402 USD
X402_EIP712_DOMAIN_VERSION=1

# ── Phase 2: Escrow contract (deploy ConfidentialEscrow.sol first) ────────────
ESCROW_CONTRACT_ADDRESS=0x...

# ── Phase 2: TEE (Phala Cloud CVM — set after deploying the CVM) ─────────────
PHALA_API_KEY=...
PHALA_CVM_ENDPOINT=https://...

# ── Agent wallet — signs on-chain transactions ────────────────────────────────
# Testnet only. Never commit a real private key.
AGENT_PRIVATE_KEY=0x...

# ── Agent scripts (agents/buyer.py, agents/seller.py) ────────────────────────
BUYER_PRIVATE_KEY=0x...
SELLER_PRIVATE_KEY=0x...
MARKET_URL=http://localhost:8000

# ── Dev mode — set to "true" to skip X-PAYMENT verification locally ──────────
# MUST be "false" (or unset) in any deployed / demo environment
SKIP_PAYMENT_CHECK=false
